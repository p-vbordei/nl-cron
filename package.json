{
  "name": "nl-cron",
  "version": "0.1.0",
  "description": "Parse natural-language schedule phrases (\"every monday at 9am\") into 5-field cron expressions. Zero dependencies.",
  "keywords": ["cron", "schedule", "natural-language", "parser", "nlp"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "Vlad Bordei",
    "email": "bordeivlad@gmail.com",
    "url": "https://github.com/p-vbordei"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/p-vbordei/nl-cron.git"
  },
  "bugs": {
    "url": "https://github.com/p-vbordei/nl-cron/issues"
  },
  "homepage": "https://github.com/p-vbordei/nl-cron#readme",
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
